# === Общие игнорируемые файлы ===
*.log
*.tmp
*~
.DS_Store
Thumbs.db

# === Docker ===
docker-compose.override.yml
.dockerignore
*.dockerfile

# Артефакты сборки Docker
/docker/build/
/docker/tmp/

# Локальные образы
*.tar
*.tgz

# === Ruby on Rails (backend/) ===
/backend/log/*.log
/backend/tmp/
/backend/.bundle/
/backend/vendor/bundle/
/backend/public/assets
/backend/public/packs
/backend/node_modules/
/backend/yarn-error.log

# PostgreSQL — не игнорируем миграции, но игнорируем локальные данные
/backend/db/*.sqlite3
/backend/db/*.dump

# Компилированные бинарные файлы Ruby
*.gem
*.rbc

# Файлы IDE
.idea/
*.sw?
*.un~
*.swo
*.swn

# Кэши
/backend/tmp/cache/
/backend/tmp/pids/
/backend/tmp/sockets/
/backend/tmp/storage/

# Локальные настройки
/backend/config/master.key
/backend/config/credentials.yml.enc

# === React (frontend/) ===
/frontend/node_modules/
/frontend/.pnp/
/frontend/.pnp.js
/frontend/dist/
