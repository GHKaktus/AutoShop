/tests/__pycache__/
/tests/*.py[cod]
/tests/*$py.class
/tests/*.so
/tests/.Python
/tests/build/
/tests/develop-eggs/
/tests/dist/
/tests/downloads/
/tests/eggs/
/tests/.eggs/
/tests/lib/
/tests/lib64/
/tests/parts/
/tests/sdist/
/tests/var/
/tests/wheels/
/tests/*.egg-info/
/tests/.installed.cfg
/tests/*.egg

# Mock‑сервер
/tests/mock-server/__pycache__/
/tests/mock-server/*.pyc
/tests/mock-server/.env
/tests/mock-server/venv/

# Виртуальные окружения для тестов
/tests/venv/
/tests/ENV/
/tests/env.bak/
/tests/venv.bak/

# Отчёты тестов
/tests/htmlcov/
/tests/.tox/
/tests/.coverage
/tests/.coverage.*
/tests/.cache
/tests/nosetests.xml
/tests/coverage.xml
/tests/*.cover
/tests/.hypothesis/

# Jupyter Notebook
/tests/.ipynb_checkpoints

# IPython
/tests/profile_default/
/tests/ipython_config.py

