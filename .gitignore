# === Общие игнорируемые файлы ===
*.log
*.tmp
*~
.DS_Store
Thumbs.db

# === Docker ===
docker-compose.override.yml
.dockerignore
*.dockerfile

# Артефакты сборки Docker
/docker/build/
/docker/tmp/

# Локальные образы
*.tar
*.tgz

# === Ruby on Rails (backend/) ===
/backend/AutoShop/.bundle/
/backend/AutoShop/vendor/bundle/
/backend/AutoShop/public/assets
/backend/AutoShop/public/packs
/backend/AutoShop/node_modules/
/backend/AutoShop/yarn-error.log

# Ignore all environment files.
/backend/AutoShop/.env*

# Ignore all logfiles and tempfiles.
/backend/AutoShop/log/*
/backend/AutoShop/tmp/*
!/backend/AutoShop/log/.keep
!/backend/AutoShop/tmp/.keep

# Ignore pidfiles, but keep the directory.
/backend/AutoShop/tmp/pids/*
!/backend/AutoShop/tmp/pids/
!/backend/AutoShop/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/backend/AutoShop/storage/*
!/backend/AutoShop/storage/.keep
/backend/AutoShop/tmp/storage/*
!/backend/AutoShop/tmp/storage/
!/backend/AutoShop/tmp/storage/.keep

# Ignore key files for decrypting credentials and more.
/backend/AutoShop/config/*.key

# PostgreSQL — не игнорируем миграции, но игнорируем локальные данные
/backend/AutoShop/db/*.sqlite3
/backend/AutoShop/db/*.dump

# Компилированные бинарные файлы Ruby
*.gem
*.rbc

# Файлы IDE
.idea/
*.sw?
*.un~
*.swo
*.swn

# Кэши
/backend/tmp/cache/
/backend/tmp/pids/
/backend/tmp/sockets/
/backend/tmp/storage/

# Локальные настройки
/backend/config/master.key
/backend/config/credentials.yml.enc

# === React (frontend/) ===
/frontend/node_modules/
/frontend/.pnp/
/frontend/.pnp.js
/frontend/dist/
/frontend/build/  # Сборка для продакшена — генерируется автоматически
/frontend/.DS_Store
/frontend/.env.local
/frontend/.env.development.local
/frontend/.env.test.local
/frontend/.env.production.local
/frontend/npm-debug.log*
/frontend/yarn-debug.log*
/frontend/yarn-error.log*

# Production
/frontend/build
/frontend/.nyc_output
/frontend/coverage/

# IDE
/frontend/.idea/
/frontend/.vscode/
/frontend/.vs/

# TypeScript
/frontend/src/react-app-env.d.ts
/frontend/src/setupProxy.js

